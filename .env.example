# Copy to .env and fill values.
# .env must sit next to main.py.

# Flask / app
PORT=2000
MINIGRAM_SECRET=change_this_secret

# Minigram
BOT_TOKEN=
ME_ID=
MINIGRAM_ENABLE_ADMIN_ROUTES=1

# AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Gmail
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_IMAP_HOST=imap.gmail.com
MAIL_IMAP_PORT=993
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=465
# MAIL_FROM=

# Optional paths / limits
# MINIOS_SETTINGS_PATH=
# DB_PATH=
# UPLOAD_DIR=
# AI_DB_PATH=
# NOTES_DB_PATH=
# FINANCE_DB_PATH=
WEATHER_CACHE_TTL=900
BOARDS_CACHE_TTL=600
NEWS_CACHE_TTL=900
